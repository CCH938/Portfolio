# LLM Configuration (支持 OpenAI / DeepSeek / 其他兼容接口)
LLM_PROVIDER=deepseek                          # openai | deepseek | custom
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1    # DeepSeek 接口
LLM_MODEL=deepseek-chat                        # DeepSeek 主力模型
LLM_MODEL_ADVANCED=deepseek-reasoner           # DeepSeek 推理模型（可选）

# 若使用 OpenAI，改为：
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL_ADVANCED=gpt-4o

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cs_agent
REDIS_URL=redis://localhost:6379/0

# Vector Store
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_data

# App
APP_NAME=智能客服 Agent
DEBUG=true
LOG_LEVEL=INFO
